# ---------------------------------------------------------------------------
# Auth.js (NextAuth) — copy this file to `.env.local` and fill in the values.
# `.env.local` is gitignored, so your secrets stay out of the repo.
# ---------------------------------------------------------------------------

# Random 32+ byte secret used to encrypt sessions/JWTs.
# Generate one with:  npx auth secret    (or)   openssl rand -base64 33
AUTH_SECRET=

# Google OAuth credentials — from https://console.cloud.google.com/apis/credentials
#   1. Create an OAuth 2.0 Client ID (Application type: Web application)
#   2. Authorized JavaScript origins:   http://localhost:3000
#   3. Authorized redirect URI:         http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ---------------------------------------------------------------------------
# MongoDB — songs, leaderboard, and GridFS audio storage.
#   1. Create a free cluster at https://cloud.mongodb.com
#   2. Database Access → add a user; Network Access → allow your IP (or 0.0.0.0/0 for dev)
#   3. Connect → Drivers → copy the connection string, put the password in it
#   4. Seed it:  node --env-file=.env.local scripts/seed.mjs
# ---------------------------------------------------------------------------
MONGODB_URI=
MONGODB_DB=maestro
